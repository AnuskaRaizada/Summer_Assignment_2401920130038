public class LibraryInterfaceDemo{
    public static void main(String[] args){
        System.out.println("Test Case - 1 : KidUser Class\n");
        KidUser kid = new KidUser();
        System.out.println("Age = 10");
        kid.registerAccount(10);
        System.out.println("Age = 18");
        kid.registerAccount(18);
        System.out.println("Book type = Kids");
        kid.requestBook("Kids");
        System.out.println("Book type = Fiction");
        kid.requestBook("Fiction");
        System.out.println();

        System.out.println("Test Case - 2 : AdultUser Class\n");
        AdultUser adult = new AdultUser();
        System.out.println("Age = 5");
        adult.registerAccount(5);
        System.out.println("Age = 23");
        adult.registerAccount(23);
        System.out.println("Book type = Kids");
        adult.requestBook("Kids");
        System.out.println("Book type = Fiction");
        adult.requestBook("Fiction");
    }
}
interface LibraryUser{
    public void registerAccount(int age);
    public void requestBook(String bookType);
}
class KidUser implements LibraryUser{
    int age;
    String bookType;
    @Override
    public void registerAccount(int age){
        if(age <= 12){
            System.out.println("You have successfully registered under a Kids Account");
        }
        else{
            System.out.println("Sorry, Age must be less than 12 to register as a kid");
        }
    }
    @Override
    public void requestBook(String bookType){
        if("Kids".equals(bookType)){
            System.out.println("Book issued successfully, please return the book within 10 days");
        }
        else{
            System.out.println("Oops, you are allowed to take only kids books");
        }
    }
}
class AdultUser implements LibraryUser{
    int age;
    String bookType;
    @Override
    public void registerAccount(int age){
        if(age > 12){
            System.out.println("You have successfully registered under an Adult Account");
        }
        else{
            System.out.println("Sorry, Age must be greater than 12 to register as an adult");
        }
    }
    @Override
    public void requestBook(String bookType){
        if("Fiction".equals(bookType)){
            System.out.println("Book issued successfully, please return the book within 7 days");
        }
        else{
            System.out.println("Oops, you are allowed to take only adult Fiction books");
        }
    }
}
