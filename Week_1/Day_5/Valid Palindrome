class Solution {
    public boolean isPalindrome(String s) {
        if(s.isEmpty()){
            return true;
        }
        int st = 0, end = s.length() - 1;
        while(st <= end){
            char currentST = s.charAt(st);
            char currentEND = s.charAt(end);
            if(!Character.isLetterOrDigit(currentST)){
                st++;
            }
            else if(!Character.isLetterOrDigit(currentEND)){
                end--;
            }
            else{
                if(Character.toLowerCase(currentST) != Character.toLowerCase(currentEND)){
                    return false;
                }
                st++;
                end--;
            }
        }
        return true;
    }
}
