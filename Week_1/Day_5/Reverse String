class Solution {
    public void reverseString(char[] s) {
        int st = 0, end = s.length - 1;
        char temp;
        for(int i = 0; i < s.length / 2; i++){
            temp = s[st];
            s[st] = s[end];
            s[end] = temp;
            st++;
            end--;
        }
    }
}
