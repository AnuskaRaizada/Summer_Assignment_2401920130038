class Solution {
    public int maxSubArray(int[] nums) {
        int largestSum = Integer.MIN_VALUE, currentSum = 0;
        for(int i = 0; i < nums.length; i++){
            currentSum += nums[i];
            if(currentSum > largestSum){
                largestSum = currentSum;
            }
            if(currentSum < 0){
                currentSum = 0;
            }
        }
        return largestSum;
    }
}
