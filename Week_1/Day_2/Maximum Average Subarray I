class Solution {
    public double findMaxAverage(int[] nums, int k) {
        int sum = 0, maxSum;
        double maxAvg;
        for(int i = 0; i < k; i++){
            sum += nums[i];
        }
        maxSum = sum;
        for(int i = k; i < nums.length; i++){
            sum = sum - nums[i - k] + nums[i];
            if(maxSum < sum){
                maxSum = sum;
            }

        }
        maxAvg = (double)maxSum / k;
        return maxAvg;
    }
}
